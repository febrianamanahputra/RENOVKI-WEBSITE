rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidLocation(data) {
      return data.keys().hasOnly(['name', 'pekanAktif', 'startDate', 'pekanList', 'workspaceId', 'createdBy', 'createdAt', 'updatedAt'])
        && (!('name' in data) || (data.name is string && data.name.size() <= 200))
        && (!('pekanAktif' in data) || (data.pekanAktif is string && data.pekanAktif.size() <= 20))
        && (!('startDate' in data) || (data.startDate is string && data.startDate.size() <= 30))
        && (!('pekanList' in data) || (data.pekanList is list && data.pekanList.size() <= 200))
        && (!('workspaceId' in data) || data.workspaceId == 'global')
        && (!('createdBy' in data) || (data.createdBy is string && data.createdBy.size() <= 128))
        && (!('createdAt' in data) || data.createdAt is timestamp)
        && (!('updatedAt' in data) || data.updatedAt is timestamp);
    }
    
    function checkLocationCreate(data) {
      return data.keys().hasAll(['name', 'workspaceId', 'createdAt', 'updatedAt', 'createdBy'])
        && data.keys().size() >= 5
        && data.workspaceId == 'global'
        && data.createdBy == request.auth.uid
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidLocationChildren(data) {
      // Sampul, Bobot, TimeSchedule common validation
      return (!('locationId' in data) || (data.locationId is string && data.locationId.size() <= 128))
        && (!('updatedBy' in data) || (data.updatedBy is string && data.updatedBy.size() <= 128))
        && (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    match /locations/{locationId} {
      allow get: if isVerified() && isValidId(locationId);
      allow list: if isVerified() && existing().workspaceId == 'global';

      allow create: if isVerified()
        && isValidId(locationId)
        && isValidLocation(incoming())
        && checkLocationCreate(incoming());

      allow update: if isVerified()
        && isValidId(locationId)
        && isValidLocation(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().createdBy == existing().createdBy
        && incoming().workspaceId == existing().workspaceId
        && incoming().updatedAt == request.time;

      allow delete: if isVerified() && isValidId(locationId) && existing().workspaceId == 'global';

      // SUBCOLLECTIONS 
      match /sampul/{sampulId} {
        allow get: if isVerified() && isValidId(locationId) && isValidId(sampulId) && exists(/databases/$(database)/documents/locations/$(locationId));
        allow list: if isVerified() && existing().locationId == locationId && exists(/databases/$(database)/documents/locations/$(locationId));
        allow create: if isVerified() && isValidId(locationId) && exists(/databases/$(database)/documents/locations/$(locationId))
                      && isValidLocationChildren(incoming())
                      && incoming().locationId == locationId
                      && incoming().updatedBy == request.auth.uid
                      && incoming().updatedAt == request.time;
        allow update: if isVerified() && isValidId(locationId) && exists(/databases/$(database)/documents/locations/$(locationId))
                      && isValidLocationChildren(incoming())
                      && incoming().locationId == existing().locationId
                      && incoming().updatedBy == request.auth.uid
                      && incoming().updatedAt == request.time;
        allow delete: if isVerified() && isValidId(locationId) && existing().locationId == locationId;
      }

      match /bobot/{bobotId} {
        allow get: if isVerified() && isValidId(locationId) && isValidId(bobotId) && exists(/databases/$(database)/documents/locations/$(locationId));
        allow list: if isVerified() && existing().locationId == locationId && exists(/databases/$(database)/documents/locations/$(locationId));
        allow create: if isVerified() && isValidId(locationId) && exists(/databases/$(database)/documents/locations/$(locationId))
                      && isValidLocationChildren(incoming())
                      && incoming().locationId == locationId
                      && incoming().updatedBy == request.auth.uid
                      && incoming().updatedAt == request.time;
        allow update: if isVerified() && isValidId(locationId) && exists(/databases/$(database)/documents/locations/$(locationId))
                      && isValidLocationChildren(incoming())
                      && incoming().locationId == existing().locationId
                      && incoming().updatedBy == request.auth.uid
                      && incoming().updatedAt == request.time;
        allow delete: if isVerified() && isValidId(locationId) && existing().locationId == locationId;
      }

      match /timeschedule/{tsId} {
        allow get: if isVerified() && isValidId(locationId) && isValidId(tsId) && exists(/databases/$(database)/documents/locations/$(locationId));
        allow list: if isVerified() && existing().locationId == locationId && exists(/databases/$(database)/documents/locations/$(locationId));
        allow create: if isVerified() && isValidId(locationId) && exists(/databases/$(database)/documents/locations/$(locationId))
                      && isValidLocationChildren(incoming())
                      && incoming().locationId == locationId
                      && incoming().updatedBy == request.auth.uid
                      && incoming().updatedAt == request.time;
        allow update: if isVerified() && isValidId(locationId) && exists(/databases/$(database)/documents/locations/$(locationId))
                      && isValidLocationChildren(incoming())
                      && incoming().locationId == existing().locationId
                      && incoming().updatedBy == request.auth.uid
                      && incoming().updatedAt == request.time;
        allow delete: if isVerified() && isValidId(locationId) && existing().locationId == locationId;
      }
    }
  }
}
